# Groq — free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama — runs locally, no key needed
# Make sure Ollama is running: ollama serve
# Models used: mistral:7b, qwen2.5:3b, qwen3:4b, nomic-embed-text

# RAGFlow — self-hosted, run via Docker
# docker-compose -f ragflow/docker-compose.yml up -d
RAGFLOW_BASE_URL=http://localhost:80
RAGFLOW_API_KEY=ragflow-your-api-key-here
